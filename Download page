<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Téléchargement — MSFS CoPilot</title>
  <meta name="description" content="Téléchargement MSFS CoPilot — NavCrew" />
  <meta name="robots" content="noindex" />

  <style>
    :root{
      --bg0:#070b12;
      --bg1:#071a26;
      --stroke:rgba(255,255,255,.10);
      --text:#e8f0f4;
      --muted:#b6c7d3;
      --shadow: 0 20px 50px rgba(0,0,0,.55);
      --max:900px;
    }
    *{box-sizing:border-box}
    html,body{height:100%}
    body{
      margin:0;
      font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
      color:var(--text);
      background:
        radial-gradient(900px 540px at 30% 0%, rgba(91,226,255,.12), transparent 60%),
        radial-gradient(900px 540px at 80% 10%, rgba(43,147,255,.10), transparent 60%),
        radial-gradient(circle at top, var(--bg1), var(--bg0));
      overflow-x:hidden;
    }
    a{color:inherit;text-decoration:none}
    .wrap{max-width:var(--max); margin:0 auto; padding:22px 16px 70px;}

    .top{
      display:flex; align-items:center; justify-content:space-between; gap:14px;
      padding:12px 14px;
      border:1px solid var(--stroke);
      border-radius:22px;
      background:linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.03));
      box-shadow:var(--shadow);
      backdrop-filter: blur(10px);
      position:sticky; top:12px; z-index:20;
    }
    .brand{display:flex; align-items:center; gap:12px; min-width:0;}
    .logos{
      display:flex; align-items:center; gap:10px;
      padding:6px 10px;
      border:1px solid rgba(255,255,255,.08);
      background:rgba(0,0,0,.16);
      border-radius:999px;
    }
    .logos .sep{width:1px;height:28px;background:rgba(255,255,255,.10);border-radius:99px;}
    .logoNC{
      width:44px;height:44px;object-fit:contain;border-radius:50%;
      filter: drop-shadow(0 10px 16px rgba(0,0,0,.55)) drop-shadow(0 0 18px rgba(91,226,255,.12));
      opacity:.99;
    }
    .logoApp{width:38px;height:38px;object-fit:contain;filter: drop-shadow(0 10px 16px rgba(0,0,0,.55));}
    .t{display:flex; flex-direction:column; min-width:0;}
    .name{font-weight:900; letter-spacing:.2px; line-height:1.08}
    .sub{color:var(--muted); font-size:12.5px; line-height:1.25; white-space:normal}

    .nav{display:flex; gap:10px; flex-wrap:wrap; justify-content:flex-end; align-items:center;}

    .btn{
      display:inline-flex; align-items:center; justify-content:center;
      padding:9px 12px; border-radius:12px; border:1px solid var(--stroke);
      background:rgba(0,0,0,.22); font-weight:800; font-size:13px;
      user-select:none;
      cursor:pointer;
    }
    .btn.primary{
      border-color:rgba(91,226,255,.35);
      background:linear-gradient(180deg, rgba(91,226,255,.18), rgba(0,0,0,.25));
      color:var(--text);
    }
    .btn.primary:hover{opacity:.93}
    .btn.disabled{
      opacity:.55;
      cursor:not-allowed;
      pointer-events:none;
      filter:saturate(.85);
    }

    .pill{
      display:inline-flex;
      padding:7px 10px;
      border-radius:999px;
      border:1px solid var(--stroke);
      background:rgba(0,0,0,.18);
      color:var(--muted);
      font-size:12.5px;
      font-weight:900;
    }

    .lang{
      display:flex; align-items:center; gap:8px;
      padding:6px 8px;
      border:1px solid rgba(255,255,255,.10);
      background:rgba(0,0,0,.18);
      border-radius:999px;
    }
    .lang button{
      appearance:none;
      border:1px solid transparent;
      background:transparent;
      color:rgba(232,240,244,.70);
      font-weight:900;
      font-size:12px;
      padding:6px 9px;
      border-radius:999px;
      cursor:pointer;
    }
    .lang button:hover{
      color:var(--text);
      border-color:var(--stroke);
      background:rgba(0,0,0,.18);
    }
    .lang button.active{
      color:var(--text);
      border-color:rgba(91,226,255,.35);
      background:linear-gradient(180deg, rgba(91,226,255,.14), rgba(0,0,0,.18));
    }

    .panel{
      margin-top:16px;
      border:1px solid var(--stroke);
      border-radius:22px;
      background:linear-gradient(180deg, rgba(255,255,255,.05), rgba(0,0,0,.12));
      box-shadow:var(--shadow);
      backdrop-filter: blur(10px);
      padding:20px;
    }

    h1{margin:0 0 10px; font-size:34px; letter-spacing:.2px; line-height:1.08}
    .lead{margin:0; color:var(--muted); font-size:15px; line-height:1.7; max-width:75ch;}

    .box{
      margin-top:14px;
      border:1px solid rgba(255,255,255,.10);
      background:rgba(0,0,0,.18);
      border-radius:18px;
      padding:14px;
    }
    .row{display:flex; gap:10px; flex-wrap:wrap; align-items:center; margin-top:12px;}
    .hint{color:rgba(232,240,244,.60); font-size:12.5px; line-height:1.5; margin-top:10px;}
    .status{
      display:flex; align-items:center; gap:10px;
      margin-top:10px;
      color:rgba(232,240,244,.88);
      font-weight:900;
    }
    .dot{
      width:10px; height:10px; border-radius:999px;
      background:rgba(255,200,0,.85);
      box-shadow: 0 0 18px rgba(255,200,0,.15);
    }
    code{background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.10); padding:2px 6px; border-radius:8px; color:rgba(232,240,244,.85);}

    footer{margin-top:22px; text-align:center; color:rgba(232,240,244,.55); font-size:12.5px}

    @media (max-width: 760px){
      .top{flex-direction:column; align-items:stretch; gap:10px;}
      .brand{width:100%;}
      .nav{width:100%; justify-content:space-between;}
      .btn{padding:8px 10px; border-radius:999px;}
    }
  </style>
</head>

<body>
  <div class="wrap">
    <div class="top">
      <div class="brand">
        <div class="logos" aria-label="NavCrew et MSFS CoPilot">
          <img class="logoNC" src="./navcrew-badge-round-name.svg" alt="NavCrew" />
          <span class="sep" aria-hidden="true"></span>
          <img class="logoApp" src="./logo.png" alt="Logo MSFS CoPilot" />
        </div>
        <div class="t">
          <div class="name">MSFS CoPilot</div>
          <div class="sub" data-i18n="header_sub">par NavCrew — Assistant cockpit pour Microsoft Flight Simulator</div>
        </div>
      </div>

      <div class="nav">
        <a class="btn" href="./index.html" data-i18n="nav_home">Accueil</a>
        <span class="btn primary disabled" aria-disabled="true" data-i18n="nav_download_hold">Téléchargement (Hold)</span>

        <div class="lang" aria-label="Language">
          <button type="button" id="btn-fr" class="active">FR</button>
          <button type="button" id="btn-en">EN</button>
        </div>
      </div>
    </div>

    <div class="panel">
      <div class="pill" data-i18n="pill">Téléchargement</div>
      <h1 data-i18n="title">Téléchargement en attente</h1>

      <div class="status"><span class="dot"></span><span data-i18n="status">Hold : paiement en cours de configuration</span></div>

      <p class="lead" data-i18n="lead">
        Le téléchargement public n’est pas encore activé. Dès que Stripe est réglé, cette page proposera le bouton officiel.
      </p>

      <div class="box">
        <div class="row">
          <span class="btn primary disabled" aria-disabled="true" data-i18n="btn_download_disabled">Télécharger MSFS CoPilot</span>
          <a class="btn" href="./screenshots.html" data-i18n="btn_screens">Voir les captures</a>
        </div>

        <div class="hint" data-i18n-html="hint">
          Fichier cible : <code>MSFS-CoPilot-Setup-Latest.exe</code><br/>
          Lien final (désactivé pour l’instant) : <code>download.navcrew.app/msfs-copilot/MSFS-CoPilot-Setup-Latest.exe</code>
        </div>
      </div>

      <p class="hint" data-i18n="note">
        Astuce : tu peux garder cette page publique (noindex). Quand tout est prêt, on active le bouton et on enlève le hold.
      </p>
    </div>

    <footer data-i18n="footer">© NavCrew — MSFS CoPilot — GitHub Pages</footer>
  </div>

  <script>
    (function(){
      const translations = {
        fr: {
          header_sub: "par NavCrew — Assistant cockpit pour Microsoft Flight Simulator",
          nav_home: "Accueil",
          nav_download_hold: "Téléchargement (Hold)",
          pill: "Téléchargement",
          title: "Téléchargement en attente",
          status: "Hold : paiement en cours de configuration",
          lead: "Le téléchargement public n’est pas encore activé. Dès que Stripe est réglé, cette page proposera le bouton officiel.",
          btn_download_disabled: "Télécharger MSFS CoPilot",
          btn_screens: "Voir les captures",
          hint: "Fichier cible : <code>MSFS-CoPilot-Setup-Latest.exe</code><br/>Lien final (désactivé pour l’instant) : <code>download.navcrew.app/msfs-copilot/MSFS-CoPilot-Setup-Latest.exe</code>",
          note: "Astuce : tu peux garder cette page publique (noindex). Quand tout est prêt, on active le bouton et on enlève le hold.",
          footer: "© NavCrew — MSFS CoPilot — GitHub Pages"
        },
        en: {
          header_sub: "by NavCrew — Cockpit assistant for Microsoft Flight Simulator",
          nav_home: "Home",
          nav_download_hold: "Download (Hold)",
          pill: "Download",
          title: "Download on hold",
          status: "Hold: payment setup in progress",
          lead: "Public download isn’t enabled yet. As soon as Stripe is ready, this page will show the official download button.",
          btn_download_disabled: "Download MSFS CoPilot",
          btn_screens: "View screenshots",
          hint: "Target file: <code>MSFS-CoPilot-Setup-Latest.exe</code><br/>Final link (disabled for now): <code>download.navcrew.app/msfs-copilot/MSFS-CoPilot-Setup-Latest.exe</code>",
          note: "Tip: you can keep this page public (noindex). When everything is ready, we’ll enable the button and remove the hold.",
          footer: "© NavCrew — MSFS CoPilot — GitHub Pages"
        }
      };

      function applyLanguage(lang){
        const dict = translations[lang] || translations.fr;
        document.documentElement.setAttribute("lang", lang);

        document.querySelectorAll("[data-i18n]").forEach(el=>{
          const key = el.getAttribute("data-i18n");
          if(dict[key] !== undefined) el.textContent = dict[key];
        });

        document.querySelectorAll("[data-i18n-html]").forEach(el=>{
          const key = el.getAttribute("data-i18n-html");
          if(dict[key] !== undefined) el.innerHTML = dict[key];
        });

        const fr = document.getElementById("btn-fr");
        const en = document.getElementById("btn-en");
        if(fr && en){
          fr.classList.toggle("active", lang === "fr");
          en.classList.toggle("active", lang === "en");
        }

        try{ localStorage.setItem("msfs_lang", lang); }catch(e){}
      }

      function initLanguage(){
        let lang = "fr";
        try{ lang = localStorage.getItem("msfs_lang") || "fr"; }catch(e){}
        if(!translations[lang]) lang = "fr";
        applyLanguage(lang);
      }

      document.addEventListener("DOMContentLoaded", ()=>{
        initLanguage();
        const fr = document.getElementById("btn-fr");
        const en = document.getElementById("btn-en");
        if(fr) fr.addEventListener("click", ()=>applyLanguage("fr"));
        if(en) en.addEventListener("click", ()=>applyLanguage("en"));
      });
    })();
  </script>
</body>
</html>
